# Preferred unified DingTalk credentials for Logistics bot.
LOGISTICS_DING_CLIENT_ID=
LOGISTICS_DING_CLIENT_SECRET=
LOGISTICS_DING_ROBOT_CODE=

# Optional aliases also supported:
# DING_CLIENT_ID=
# DING_CLIENT_SECRET=
# DING_ROBOT_CODE=
# DINGTALK_APP_KEY=
# DINGTALK_APP_SECRET=
# DINGTALK_ROBOT_CODE=

# Split branch runtime workspace.
LOGISTICS_SPLIT_WORKSPACE=apps/split_bot/.bot-workspace

# Stream websocket resilience.
DING_STREAM_WS_PING_INTERVAL=30
DING_STREAM_WS_PING_TIMEOUT=120

# CP branch still uses its existing env variables for LingXing/OCR/MySQL/address book.
# See apps/cp_bot/env.example.

# Robot code is optional for menu/help replies when DingTalk sessionWebhook is available.
# Fill LOGISTICS_DING_ROBOT_CODE if private one-to-one messages or file sending require it.
